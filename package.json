{
  "name": "microgpt",
  "version": "1.0.0",
  "type": "module",
  "description": "A minimal GPT implementation in pure TypeScript, ported from @karpathy's microgpt.py",
  "scripts": {
    "train": "npx tsx src/phrases-train.ts",
    "generate": "npx tsx src/phrases-generate.ts",
    "fine-tune": "npx tsx src/phrases-fine-tune.ts",
    "book:build": "mdbook build book",
    "book:serve": "mdbook serve book --open"
  },
  "dependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.9.3"
  }
}
